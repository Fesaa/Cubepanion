.game-widget .selected {
 background-color: purple;
}

.game-widget {
 width: 100%;
}

.container {
  width: 100%;
  height: 100%;
  left: 0;
  top: 0;

  Scroll {
      width: 90%;
      top: 0;
      bottom: 0;
      margin-top: 5;
      margin-bottom: 5;
      left: 50%;
      alignment-x: center;

      .game-list {
        left: 0;
        top: 0;
        height: fit-content;
        space-between-entries: 2;
        selectable: true;
      }

      Scrollbar {
        left: 0;
        top: 0;
        width: 5;
        height: 100%;
        margin-left: 5;
      }
    }
}

Game {
  width: 100%;
  height: 24;
  padding: 1;

  .game-icon {
    left: 5%;
    top: 2;
    width: 16;
    height: 16;
  }

  .game-name {
      left: 50%;
      top: 50%;
      alignment-x: center;
      alignment-y: center;
  }

  &:selected {
    padding: 0;
    border: 1 gray;
    background-color: black;
  }
}